{
  "name": "evernote-unofficial-api",
  "version": "2.0.0",
  "description": "Unofficial Evernote API client & MCP server — reverse-engineered from the Evernote Web App",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "evernote-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/example.ts",
    "auth": "tsx src/mcp-auth.ts",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:auth": "tsx src/mcp-auth.ts",
    "start": "node dist/mcp-server.js",
    "proxy": "mcp-proxy --port 8080 -- node dist/mcp-server.js",
    "proxy:sse": "mcp-proxy --server sse --port 8080 -- node dist/mcp-server.js",
    "proxy:stream": "mcp-proxy --server stream --port 8080 -- node dist/mcp-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mcp-proxy": "^6.4.4",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
